---
const instagramUrl = 'https://www.instagram.com/marrlaserandskin';
const handle = '@marrlaserandskin';
---

<section class="instagram-section reveal" aria-labelledby="instagram-heading">
  <div class="container">
    <h2 id="instagram-heading" class="section-heading">Follow Us on Instagram</h2>
    <p class="section-handle">{handle}</p>

    <div class="instagram-feed">
      <script src="https://elfsightcdn.com/platform.js" async></script>
      <div class="elfsight-app-0c7f2597-0f9e-4906-b11b-c3442d2caf96" data-elfsight-app-lazy></div>
    </div>

    <div class="instagram-cta">
      <a href={instagramUrl} target="_blank" rel="noopener" class="instagram-button">
        Follow {handle}<span class="sr-only"> (opens in new tab)</span>
      </a>
    </div>
  </div>
</section>

<style>
  .instagram-section {
    padding-block: var(--space-20);
  }

  .section-heading {
    font-family: var(--font-heading);
    font-size: var(--font-size-3xl);
    font-weight: var(--font-weight-heading-light);
    color: var(--color-primary);
    text-align: center;
    margin-bottom: var(--space-2);
  }

  .section-handle {
    font-family: var(--font-body);
    font-size: var(--font-size-base);
    color: var(--color-neutral-500);
    text-align: center;
    margin-bottom: var(--space-10);
  }

  .instagram-feed {
    max-width: 48rem;
    margin-inline: auto;
  }

  .instagram-cta {
    text-align: center;
    margin-top: var(--space-8);
  }

  .instagram-button {
    display: inline-block;
    padding: var(--space-3) var(--space-8);
    font-family: var(--font-body);
    font-size: 0.6875rem;
    font-weight: var(--font-weight-body-medium);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-white);
    background-color: var(--color-primary);
    border-radius: var(--radius-full);
    text-decoration: none;
    transition: background-color var(--transition-fast), box-shadow var(--transition-fast);
  }

  .instagram-button:hover {
    background-color: var(--color-primary-dark);
    box-shadow: var(--shadow-md);
  }

  .instagram-button:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }

  @media (min-width: 768px) {
    .section-heading {
      font-size: var(--font-size-4xl);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .instagram-button {
      transition: none;
    }
  }
</style>
