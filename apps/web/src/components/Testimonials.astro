---
import type { Testimonial } from '@foxhue/shared';

interface Props {
  testimonials: Testimonial[];
  heading?: string;
}

const { testimonials, heading = 'In Their Own Words' } = Astro.props;
---

<section class="testimonials" aria-labelledby="testimonials-heading">
  <div class="container">
    <div class="testimonials__head">
      <span class="eyebrow">Patient Stories</span>
      <h2 id="testimonials-heading" class="testimonials__heading">{heading}</h2>
    </div>
    {testimonials.length > 0 ? (
      <div class="testimonials__grid" role="list">
        {testimonials.map((t) => (
          <article class="testimonial" role="listitem">
            <p class="testimonial__body"><span class="testimonial__open-quote" aria-hidden="true">&ldquo;</span>{t.quote}<span class="testimonial__close-quote" aria-hidden="true">&rdquo;</span></p>
            <footer class="testimonial__attr">
              <div class="testimonial__name">{t.author}</div>
              {t.service?.title && (
                <div class="testimonial__context">{t.service.title}</div>
              )}
            </footer>
          </article>
        ))}
      </div>
    ) : (
      <p class="testimonials__empty">No testimonials yet.</p>
    )}
    <div class="testimonials__cta-wrap">
      <a href="https://maps.app.goo.gl/bkVYi65dd8AGaSaCA" target="_blank" rel="noopener" class="testimonials__cta">
        View More Reviews<span class="sr-only"> on Google (opens in new tab)</span>
      </a>
    </div>
  </div>
</section>

<style>
  .testimonials {
    background-color: var(--color-secondary);
    padding-block: var(--space-20);
  }

  .testimonials__head {
    text-align: center;
    max-width: 48ch;
    margin: 0 auto var(--space-12);
  }

  .testimonials__head .eyebrow {
    color: rgba(255, 255, 255, 0.7);
  }

  .testimonials__heading {
    font-family: var(--font-heading);
    font-weight: var(--font-weight-heading-light);
    font-size: var(--font-size-3xl);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-white);
  }

  .testimonials__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
  }

  .testimonial {
    background-color: var(--color-white);
    padding: var(--space-8);
    border-radius: var(--radius-md);
  }

  .testimonial__open-quote,
  .testimonial__close-quote {
    font-family: var(--font-heading);
    font-weight: var(--font-weight-heading-light);
    font-size: 1.5em;
    color: var(--color-secondary);
    user-select: none;
  }

  .testimonial__body {
    font-family: var(--font-heading);
    font-weight: var(--font-weight-heading-light);
    font-style: italic;
    font-size: var(--font-size-lg);
    line-height: 1.55;
    color: var(--color-primary);
    margin-bottom: var(--space-6);
  }

  .testimonial__attr {
    border-top: 1px solid rgba(60, 60, 59, 0.12);
    padding-top: var(--space-4);
  }

  .testimonial__name {
    font-family: var(--font-heading);
    font-weight: var(--font-weight-heading-regular);
    font-size: 0.6875rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-primary);
    margin-bottom: var(--space-1);
  }

  .testimonial__context {
    font-family: var(--font-body);
    font-style: italic;
    font-size: var(--font-size-sm);
    color: var(--color-neutral-600);
  }

  .testimonials__cta-wrap {
    text-align: center;
    margin-top: var(--space-10);
  }

  .testimonials__cta {
    display: inline-block;
    padding: var(--space-3) var(--space-8);
    font-family: var(--font-body);
    font-size: 0.6875rem;
    font-weight: var(--font-weight-body-medium);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-white);
    background-color: transparent;
    border: 1px solid var(--color-white);
    border-radius: var(--radius-full);
    text-decoration: none;
    transition: background-color var(--transition-fast), color var(--transition-fast);
  }

  .testimonials__cta:hover {
    background-color: var(--color-white);
    color: var(--color-primary);
  }

  .testimonials__cta:focus-visible {
    outline: 2px solid var(--color-white);
    outline-offset: 2px;
  }

  .testimonials__empty {
    text-align: center;
    color: rgba(255, 255, 255, 0.7);
    font-size: var(--font-size-lg);
  }

  @media (min-width: 768px) {
    .testimonials__grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (min-width: 1024px) {
    .testimonials__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
