---
import type { TeamMember, SanityBlock } from '@foxhue/shared';
import SanityImage from '@components/SanityImage.astro';
import PortableText from '@components/PortableText.astro';
import { BOOKING_LINK } from '@lib/constants';

interface Props {
  members: TeamMember[];
}

const { members } = Astro.props;

const teamFallbackPhotos: Record<string, string> = {
  'Emma': '/images/team/emma.jpg',
  'Jennifer Graham': '/images/team/jennifer.jpg',
  'Fraser': '/images/team/fraser.jpg',
  'Katie': '/images/team/katie.jpg',
};

/**
 * Extract the first paragraph from portable text blocks for a bio excerpt.
 */
function extractFirstParagraph(bio: SanityBlock[] | undefined): string {
  if (!bio || bio.length === 0) return '';
  const firstBlock = bio.find((b) => b._type === 'block');
  if (!firstBlock) return '';
  return (firstBlock.children ?? []).map((c) => c.text ?? '').join('');
}

function hasExpandableContent(member: TeamMember): boolean {
  return !!(member.bio && member.bio.length > 0) || !!(member.qualifications && member.qualifications.length > 0) || !!(member.specialisms && member.specialisms.length > 0);
}

function getFirstName(name: string): string {
  return name.split(' ')[0];
}

function padIndex(i: number): string {
  return String(i + 1).padStart(2, '0');
}
---

<section class="team-section reveal" aria-labelledby="team-heading">
  <h2 id="team-heading" class="sr-only">Our Team</h2>

  {members.length > 0 ? (
    <div class="team-rows">
      {members.map((member, i) => {
        const snippet = extractFirstParagraph(member.bio);
        const expandable = hasExpandableContent(member);
        const isReversed = i % 2 === 1;
        const accordionId = `accordion-${member._id}`;
        return (
          <article class={`team-row${isReversed ? ' team-row--reversed' : ''}`}>
            {/* Photo column */}
            <div class="team-row__photo">
              <div class="team-row__photo-frame">
                {member.photo ? (
                  <SanityImage
                    source={member.photo.image}
                    alt={member.photo.alt || member.name}
                    width={600}
                    height={750}
                    class="team-row__img"
                    loading={i === 0 ? 'eager' : 'lazy'}
                    fetchpriority={i === 0 ? 'high' : undefined}
                  />
                ) : (
                  <img
                    src={teamFallbackPhotos[member.name] || '/placeholders/team.svg'}
                    alt={member.name}
                    width={600}
                    height={750}
                    class="team-row__img"
                    loading={i === 0 ? 'eager' : 'lazy'}
                    decoding={i === 0 ? 'sync' : 'async'}
                    fetchpriority={i === 0 ? 'high' : undefined}
                  />
                )}
                <span class="team-row__number" aria-hidden="true">{padIndex(i)}</span>
              </div>
            </div>

            {/* Content column */}
            <div class="team-row__content">
              <p class="eyebrow">Team &middot; {member.role || 'Practitioner'}</p>
              <h3 class="team-row__name">{member.name}</h3>
              {member.role && <p class="team-row__role">{member.role}</p>}

              {member.quote && (
                <blockquote class="team-row__quote">
                  <span class="team-row__quote-mark" aria-hidden="true">&ldquo;</span>
                  {member.quote}
                </blockquote>
              )}

              {snippet && <p class="team-row__bio">{snippet}</p>}

              {member.specialisms && member.specialisms.length > 0 && (
                <ul class="team-row__tags" role="list" aria-label={`${member.name}'s specialisms`}>
                  {member.specialisms.map((s) => (
                    <li class="team-row__tag">{s}</li>
                  ))}
                </ul>
              )}

              {expandable && (
                <button
                  type="button"
                  class="team-row__cta"
                  data-accordion-trigger={accordionId}
                  aria-expanded="false"
                  aria-controls={accordionId}
                  aria-label={`Read full profile for ${member.name}`}
                >
                  <span class="team-row__cta-text">Read full profile</span> <span class="team-row__cta-arrow" aria-hidden="true">&darr;</span>
                </button>
              )}

              {/* Inline accordion panel */}
              {expandable && (
                <div class="team-row__expand" id={accordionId} hidden>
                  <div class="team-row__expand-inner">
                    {member.bio && member.bio.length > 0 && (
                      <div class="team-row__section">
                        <p class="team-row__section-label">Biography</p>
                        <div class="team-row__full-bio">
                          <PortableText value={member.bio} />
                        </div>
                      </div>
                    )}

                    {member.qualifications && member.qualifications.length > 0 && (
                      <div class="team-row__section">
                        <p class="team-row__section-label">Qualifications</p>
                        <ul class="team-row__tags" role="list">
                          {member.qualifications.map((q) => (
                            <li class="team-row__tag">{q}</li>
                          ))}
                        </ul>
                      </div>
                    )}

                    <a
                      href={BOOKING_LINK}
                      class="team-row__book"
                      data-booking
                    >
                      Book with {getFirstName(member.name)}
                    </a>
                  </div>
                </div>
              )}
            </div>
          </article>
        );
      })}
    </div>
  ) : (
    <div class="container">
      <p class="team-empty">Team information coming soon.</p>
    </div>
  )}
</section>

<style>
  /* -----------------------------------------------------------
     Alternating Rows
  ----------------------------------------------------------- */
  .team-section {
    padding-block: var(--space-4) var(--space-16);
  }

  .team-rows {
    display: flex;
    flex-direction: column;
    gap: var(--space-16);
  }

  .team-row {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
    max-width: var(--max-width);
    margin-inline: auto;
    padding-inline: var(--space-6);
    align-items: start;
  }

  .team-empty {
    text-align: center;
    color: var(--color-neutral-500);
    font-size: var(--font-size-lg);
  }

  /* Photo column */
  .team-row__photo {
    order: 0;
  }

  .team-row__photo-frame {
    position: relative;
    aspect-ratio: 4 / 5;
    border-radius: var(--radius-lg);
    overflow: hidden;
  }

  .team-row__photo-frame :global(img),
  .team-row__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: saturate(0.92);
    transition: transform var(--transition-slow);
    will-change: transform;
  }

  .team-row__photo-frame:hover :global(img),
  .team-row__photo-frame:hover .team-row__img {
    filter: saturate(1);
    transform: scale(1.02);
  }

  .team-row__number {
    position: absolute;
    bottom: var(--space-4);
    left: var(--space-4);
    font-family: var(--font-heading);
    font-size: var(--font-size-4xl);
    font-weight: var(--font-weight-heading-light);
    color: var(--color-white);
    line-height: 1;
    text-shadow: 0 2px 12px rgba(0, 0, 0, 0.3);
  }

  /* Content column */
  .team-row__content {
    order: 1;
  }

  .team-row__name {
    font-family: var(--font-heading);
    font-size: var(--font-size-3xl);
    font-weight: var(--font-weight-heading-light);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-primary);
    margin-bottom: var(--space-1);
  }

  .team-row__role {
    font-family: var(--font-heading);
    font-size: var(--font-size-lg);
    font-style: italic;
    font-weight: var(--font-weight-heading-regular);
    color: var(--color-neutral-500);
    margin-bottom: var(--space-6);
  }

  .team-row__quote {
    position: relative;
    padding-left: var(--space-6);
    border-left: 2px solid var(--color-secondary);
    font-family: var(--font-heading);
    font-size: var(--font-size-lg);
    font-style: italic;
    font-weight: var(--font-weight-heading-regular);
    color: var(--color-neutral-600);
    line-height: 1.6;
    margin-bottom: var(--space-6);
  }

  .team-row__quote-mark {
    position: absolute;
    top: -0.2em;
    left: var(--space-2);
    font-size: var(--font-size-3xl);
    color: var(--color-secondary);
    line-height: 1;
  }

  .team-row__bio {
    font-size: var(--font-size-base);
    color: var(--color-neutral-600);
    line-height: 1.7;
    margin-bottom: var(--space-6);
    display: -webkit-box;
    -webkit-line-clamp: 4;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .team-row__tags {
    list-style: none;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-bottom: var(--space-6);
  }

  .team-row__tag {
    font-size: var(--font-size-sm);
    color: var(--color-neutral-600);
    padding: var(--space-1) var(--space-3);
    background-color: var(--color-accent);
    border-radius: var(--radius-full);
  }

  /* CTA toggle button */
  .team-row__cta {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-body);
    font-size: 0.6875rem;
    font-weight: var(--font-weight-body-medium);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-secondary-dark, var(--color-secondary));
    background: none;
    border: none;
    border-bottom: 1px solid currentColor;
    cursor: pointer;
    padding: 0;
    transition: color var(--transition-fast);
  }

  .team-row__cta:hover {
    color: var(--color-primary);
  }

  .team-row__cta:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 3px;
  }

  .team-row__cta-arrow {
    display: inline-block;
    transition: transform var(--transition-fast);
  }

  .team-row__cta[aria-expanded="true"] .team-row__cta-arrow {
    transform: rotate(180deg);
  }

  /* -----------------------------------------------------------
     Inline Accordion
  ----------------------------------------------------------- */
  .team-row__expand {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 400ms ease;
    margin-top: var(--space-6);
  }

  .team-row__expand[hidden] {
    display: grid;
    grid-template-rows: 0fr;
  }

  .team-row__expand.is-open {
    grid-template-rows: 1fr;
  }

  .team-row__expand-inner {
    overflow: hidden;
  }

  .team-row__section {
    margin-bottom: var(--space-6);
  }

  .team-row__section-label {
    font-family: var(--font-heading);
    font-size: 0.6875rem;
    font-weight: var(--font-weight-heading-regular);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-primary);
    margin-bottom: var(--space-3);
  }

  .team-row__full-bio {
    font-size: var(--font-size-base);
    color: var(--color-neutral-600);
    line-height: 1.7;
  }

  .team-row__full-bio :global(p) {
    margin-bottom: var(--space-4);
  }

  .team-row__full-bio :global(p:last-child) {
    margin-bottom: 0;
  }

  .team-row__book {
    display: inline-block;
    margin-top: var(--space-2);
    margin-bottom: var(--space-2);
    padding: var(--space-3) var(--space-8);
    font-family: var(--font-body);
    font-size: 0.6875rem;
    font-weight: var(--font-weight-body-medium);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    text-decoration: none;
    color: var(--color-white);
    background-color: var(--color-secondary);
    border-radius: var(--radius-full);
    transition: background-color var(--transition-fast);
  }

  .team-row__book:hover {
    background-color: var(--color-secondary-dark);
  }

  .team-row__book:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 3px;
  }

  /* Screen-reader only */
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* Desktop: 2-column grid */
  @media (min-width: 768px) {
    .team-row {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-12);
    }

    /* Reversed rows swap column order */
    .team-row--reversed .team-row__photo {
      order: 1;
    }

    .team-row--reversed .team-row__content {
      order: 0;
    }
  }

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .team-row__expand,
    .team-row__cta-arrow,
    .team-row__photo-frame :global(img),
    .team-row__photo-frame .team-row__img {
      transition: none;
    }
  }
</style>

<script>
  document.addEventListener('click', (e) => {
    const trigger = (e.target as HTMLElement).closest('[data-accordion-trigger]') as HTMLElement;
    if (!trigger) return;

    const panelId = trigger.getAttribute('data-accordion-trigger');
    if (!panelId) return;

    const panel = document.getElementById(panelId);
    if (!panel) return;

    const isOpen = trigger.getAttribute('aria-expanded') === 'true';
    const textEl = trigger.querySelector('.team-row__cta-text');

    if (isOpen) {
      // Close
      panel.classList.remove('is-open');
      trigger.setAttribute('aria-expanded', 'false');
      if (textEl) textEl.textContent = 'Read full profile';

      // Hide after transition completes
      panel.addEventListener('transitionend', () => {
        if (trigger.getAttribute('aria-expanded') === 'false') {
          panel.hidden = true;
        }
      }, { once: true });
    } else {
      // Open — remove hidden first so transition can run
      panel.hidden = false;

      // Force a reflow before adding the class so the transition fires
      panel.offsetHeight;

      panel.classList.add('is-open');
      trigger.setAttribute('aria-expanded', 'true');
      if (textEl) textEl.textContent = 'Close profile';
    }
  });
</script>
