---
import type { SanityImage as SanityImageType } from '@foxhue/shared';
import { sanityImageUrl } from '@lib/image';

interface Props {
  heading: string;
  tagline?: string;
  image?: SanityImageType;
  ctaText?: string;
  ctaUrl?: string;
  eyebrow?: string;
  secondaryCtaText?: string;
  secondaryCtaUrl?: string;
}

const { heading, tagline, image, ctaText, ctaUrl, eyebrow, secondaryCtaText, secondaryCtaUrl } = Astro.props;

const bgImageUrl = image ? sanityImageUrl(image, 1920, 1080) : null;
---

<section class="hero" aria-labelledby="hero-heading" data-hero>
  <div class="hero-text">
    <div class="hero-text-inner">
      {eyebrow && <span class="eyebrow">{eyebrow}</span>}
      <h1 id="hero-heading" class="hero-heading">{heading}</h1>
      {tagline && <p class="hero-tagline">{tagline}</p>}
      <div class="hero-cta-group">
        {ctaText && ctaUrl && (
          <a href={ctaUrl} class="hero-cta hero-cta--primary"
             {...(ctaUrl?.includes('phorest') && { 'data-booking': '' })}>
            {ctaText}
          </a>
        )}
        {secondaryCtaText && secondaryCtaUrl && (
          <a href={secondaryCtaUrl} class="hero-cta hero-cta--outline">
            {secondaryCtaText}
          </a>
        )}
      </div>
    </div>
  </div>

  <div class="hero-media">
    <video
      class="hero-video"
      autoplay
      muted
      loop
      playsinline
      preload="auto"
      poster="/images/hero-poster.jpg"
    >
      <source src="/videos/hero.mp4" type="video/mp4" />
    </video>
    <img
      src="/images/hero-poster.jpg"
      alt=""
      class="hero-image hero-image--fallback"
      loading="eager"
      fetchpriority="high"
      width="1920"
      height="1080"
    />
  </div>
</section>

<style>
  .hero {
    display: flex;
    flex-direction: column;
    min-height: 100vh;
    min-height: 100svh;
  }

  /* Text panel — charcoal background */
  .hero-text {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-24) var(--space-6) var(--space-12);
    background-color: var(--color-accent);
  }

  .hero-text-inner {
    max-width: 32rem;
  }

  .eyebrow {
    display: inline-block;
    font-family: var(--font-heading);
    font-size: 0.6875rem;
    font-weight: var(--font-weight-heading-regular);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-secondary);
    margin-bottom: var(--space-4);
  }

  .hero-heading {
    font-family: var(--font-heading);
    font-size: var(--font-size-4xl);
    font-weight: var(--font-weight-heading-light);
    line-height: 1.15;
    color: var(--color-primary);
    margin-bottom: var(--space-5);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .hero-tagline {
    font-family: var(--font-body);
    font-size: var(--font-size-base);
    font-weight: var(--font-weight-body-light);
    line-height: 1.65;
    color: var(--color-neutral-700);
    margin-bottom: var(--space-8);
    letter-spacing: var(--body-letter-spacing);
  }

  .hero-cta-group {
    display: flex;
    gap: var(--space-3);
    flex-wrap: wrap;
  }

  .hero-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-3) var(--space-8);
    font-family: var(--font-body);
    font-weight: var(--font-weight-body-medium);
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    border-radius: var(--radius-full);
    text-decoration: none;
    border: 1px solid transparent;
    transition: background-color var(--transition-base), color var(--transition-base), border-color var(--transition-base);
  }

  .hero-cta--primary {
    background-color: var(--color-secondary);
    color: var(--color-white);
    border-color: var(--color-secondary);
  }

  .hero-cta--primary:hover {
    background-color: var(--color-secondary-dark);
    border-color: var(--color-secondary-dark);
  }

  .hero-cta--outline {
    background-color: transparent;
    color: var(--color-primary);
    border-color: var(--color-primary);
  }

  .hero-cta--outline:hover {
    background-color: var(--color-primary);
    color: var(--color-white);
  }

  .hero-cta:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }

  /* Video / media panel */
  .hero-media {
    position: relative;
    flex: 1;
    min-height: 50vh;
    overflow: hidden;
  }

  .hero-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .hero-image--fallback {
    display: none;
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-video {
      display: none;
    }

    .hero-image--fallback {
      display: block;
    }
  }

  /* Desktop — side-by-side 50/50 */
  @media (min-width: 768px) {
    .hero {
      flex-direction: row;
    }

    .hero-text {
      width: 50%;
      padding: var(--space-24) var(--space-12);
    }

    .hero-media {
      width: 50%;
      min-height: auto;
    }

    .hero-heading {
      font-size: var(--font-size-5xl);
    }

    .hero-tagline {
      font-size: var(--font-size-lg);
    }
  }

  @media (min-width: 1024px) {
    .hero-text {
      padding: var(--space-24) var(--space-16);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-cta {
      transition: none;
    }
  }
</style>
