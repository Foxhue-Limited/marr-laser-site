---
import PortableText from '@components/PortableText.astro';
import type { SanityBlock } from '@foxhue/shared';

interface Section {
  heading: string;
  blocks: SanityBlock[];
  image: { src: string; alt: string };
}

interface Props {
  sections: Section[];
}

const { sections } = Astro.props;
---

<div class="treatment-sections">
  {sections.map((section, i) => {
    const isReversed = i % 2 === 1;
    return (
      <div class={`treatment-row reveal${isReversed ? ' treatment-row--reversed' : ''}`}>
        <div class="treatment-row__image">
          <img
            src={section.image.src}
            alt={section.image.alt}
            width={600}
            height={400}
            loading="lazy"
            decoding="async"
          />
        </div>
        <div class="treatment-row__content">
          <h2>{section.heading}</h2>
          {section.blocks.length > 3 ? (
            <>
              <PortableText value={[section.blocks[0]]} />
              <div class="treatment-expand__body" hidden>
                <PortableText value={section.blocks.slice(1)} />
              </div>
              <button class="treatment-expand__btn" type="button">Learn More</button>
            </>
          ) : (
            <PortableText value={section.blocks} />
          )}
        </div>
      </div>
    );
  })}
</div>

<style>
  .treatment-sections {
    display: flex;
    flex-direction: column;
    gap: var(--space-24);
    padding-bottom: var(--space-16);
  }

  .treatment-row {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
    max-width: var(--max-width);
    margin-inline: auto;
    padding-inline: var(--space-6);
    align-items: center;
  }

  .treatment-row__image {
    order: 0;
  }

  .treatment-row__image img {
    width: 100%;
    height: auto;
    aspect-ratio: 3 / 2;
    object-fit: cover;
    display: block;
    border: 3px solid var(--color-secondary);
    border-radius: 15px;
  }

  .treatment-row__content {
    order: 1;
  }

  .treatment-expand__btn {
    display: inline-flex;
    align-items: center;
    margin-top: var(--space-4);
    padding: var(--space-2) var(--space-6);
    font-family: var(--font-body);
    font-size: 0.6875rem;
    font-weight: var(--font-weight-body-medium);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-primary);
    background: transparent;
    border: 1px solid var(--color-secondary);
    border-radius: var(--radius-lg);
    cursor: pointer;
    transition: background-color var(--transition-base), color var(--transition-base);
  }

  .treatment-expand__btn:hover {
    background-color: var(--color-secondary);
    color: var(--color-white);
  }

  @media (min-width: 768px) {
    .treatment-row {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-12);
    }

    .treatment-row--reversed .treatment-row__image {
      order: 1;
    }

    .treatment-row--reversed .treatment-row__content {
      order: 0;
    }
  }
</style>

<script>
  document.querySelectorAll<HTMLButtonElement>('.treatment-expand__btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const body = btn.previousElementSibling as HTMLElement;
      const expanded = !body.hidden;
      body.hidden = expanded;
      btn.textContent = expanded ? 'Learn More' : 'Read Less';
    });
  });
</script>
