---
import BaseLayout from '@layouts/BaseLayout.astro';
import SanityImage from '@components/SanityImage.astro';
import PortableText from '@components/PortableText.astro';
import TreatmentSection from '@components/TreatmentSection.astro';
import CTABanner from '@components/CTABanner.astro';
import { sanityClient } from '@lib/sanity';
import { servicesQuery, serviceBySlugQuery } from '@lib/queries';
import type { Service, SanityBlock } from '@foxhue/shared';

export async function getStaticPaths() {
  const services: Service[] = await sanityClient.fetch(servicesQuery);

  return services.map((service) => ({
    params: { slug: service.slug.current },
  }));
}

const { slug } = Astro.params;
const service: Service = await sanityClient.fetch(serviceBySlugQuery, { slug });

if (!service) {
  return Astro.redirect('/404');
}

const serviceFallbackHeroes: Record<string, string> = {
  'laser-treatments': '/images/services/laser-hero.jpg',
  'skin-treatments': '/images/services/skin-hero.webp',
  'aesthetic-treatments': '/images/services/aesthetic-hero.jpg',
  'pmu-treatments': '/images/services/pmu-hero.jpg',
  'caci-treatments': '/images/services/caci-hero.webp',
};
const fallbackHero = serviceFallbackHeroes[slug as string] || '/placeholders/service-hero.svg';

/* ── Section image maps per slug ── */
const sectionImageMap: Record<string, { src: string; alt: string }[]> = {
  'laser-treatments': [
    { src: '/images/services/laser/laser-hair-removal.webp', alt: 'Laser hair removal treatment' },
    { src: '/images/services/laser/pigmented.webp', alt: 'Pigmented lesion treatment' },
    { src: '/images/services/laser/thread-vein.webp', alt: 'Thread vein removal treatment' },
    { src: '/images/services/laser/fungal-nail.webp', alt: 'Fungal nail treatment' },
    { src: '/images/services/laser/moveo.webp', alt: 'Skin rejuvenation with Moveo SR' },
  ],
  'skin-treatments': [
    { src: '/images/services/skin/hifu.webp', alt: 'HIFU treatment' },
    { src: '/images/services/skin/radio-frequency.webp', alt: 'RF microneedling treatment' },
    { src: '/images/services/skin/illuminfacial.webp', alt: 'IllumiFacial treatment' },
    { src: '/images/services/skin/acne.webp', alt: 'Acne treatment' },
    { src: '/images/services/skin/biorepeel.webp', alt: 'BioRePeel treatment' },
    { src: '/images/services/skin/image-skincare.webp', alt: 'IMAGE Skincare designer peels' },
    { src: '/images/services/skin/dermalux.webp', alt: 'Dermalux LED phototherapy treatment' },
  ],
  'aesthetic-treatments': [
    { src: '/images/services/aesthetic/anti-ageing.jpg', alt: 'Anti-ageing treatments' },
    { src: '/images/services/aesthetic/lip-enhancement.jpg', alt: 'Lip enhancement treatment' },
    { src: '/images/services/aesthetic/tear-trough.jpg', alt: 'Tear trough filler treatment' },
    { src: '/images/services/aesthetic/facial-contouring.png', alt: 'Facial contouring treatment' },
    { src: '/images/services/aesthetic/nasolabial.jpg', alt: 'Nasolabial fold and marionette lines treatment' },
    { src: '/images/services/aesthetic/perioral.jpg', alt: 'Perioral lines treatment' },
    { src: '/images/services/aesthetic/profhilo.jpg', alt: 'Profhilo treatment' },
  ],
  'pmu-treatments': [
    { src: '/images/services/pmu/barely-there-brows.webp', alt: 'Barely there brows treatment' },
    { src: '/images/services/pmu/microblading.webp', alt: 'Microblading treatment' },
    { src: '/images/services/pmu/ombre-brows.webp', alt: 'Ombre brows treatment' },
    { src: '/images/services/pmu/combination-brows.webp', alt: 'Combination brows treatment' },
  ],
  'caci-treatments': [
    { src: '/images/services/caci/signature-facial.webp', alt: 'CACI signature non-surgical facial treatment' },
    { src: '/images/services/caci/microdermabrasion.webp', alt: 'CACI microdermabrasion treatment' },
    { src: '/images/services/caci/ultimate-facial.webp', alt: 'CACI ultimate non-surgical facial treatment' },
    { src: '/images/services/caci/jowl-lift.webp', alt: 'CACI jowl lift treatment' },
    { src: '/images/services/caci/eye-revive.webp', alt: 'CACI eye revive treatment' },
    { src: '/images/services/caci/hand-rejuvenation.webp', alt: 'CACI hand rejuvenation treatment' },
  ],
};

/* ── Split body at h2 headings ── */
function splitByH2(blocks: SanityBlock[]): { intro: SanityBlock[]; sections: { heading: string; blocks: SanityBlock[] }[] } {
  const intro: SanityBlock[] = [];
  const sections: { heading: string; blocks: SanityBlock[] }[] = [];
  let current: { heading: string; blocks: SanityBlock[] } | null = null;

  for (const block of blocks) {
    if (block._type === 'block' && block.style === 'h2') {
      const heading = (block.children ?? []).map((c) => c.text ?? '').join('');
      current = { heading, blocks: [] };
      sections.push(current);
    } else if (current) {
      current.blocks.push(block);
    } else {
      intro.push(block);
    }
  }

  return { intro, sections };
}

const images = sectionImageMap[slug as string];
const hasSections = !!(images && service.body);

let introBlocks: SanityBlock[] = [];
let treatmentSections: { heading: string; blocks: SanityBlock[]; image: { src: string; alt: string } }[] = [];
if (hasSections) {
  const { intro, sections: groups } = splitByH2(service.body!);
  introBlocks = intro;
  treatmentSections = groups.map((group, i) => ({
    ...group,
    image: images[i] || { src: '', alt: '' },
  }));
}
---

<BaseLayout
  title={service.seo?.title ?? service.title}
  description={service.seo?.description ?? service.excerpt}
>
  <article class="service-detail">
    <div class="service-hero">
      {service.image ? (
        <SanityImage
          source={service.image.image}
          alt={service.image.alt}
          width={1200}
          height={600}
        />
      ) : (
        <img src={fallbackHero} alt={service.title} width={1200} height={600} loading="eager" decoding="async" />
      )}
    </div>

    <div class="container">
      <div class="service-header">
        <h1>{service.title}</h1>

        {(service.price || service.duration) && (
          <div class="service-meta" role="list" aria-label="Service details">
            {service.price && (
              <span class="badge" role="listitem">{service.price}</span>
            )}
            {service.duration && (
              <span class="badge" role="listitem">{service.duration}</span>
            )}
          </div>
        )}
      </div>

      {hasSections && treatmentSections.length > 0 ? (
        <>
          {introBlocks.length > 0 && (
            <div class="service-body prose">
              <PortableText value={introBlocks} />
            </div>
          )}
          <TreatmentSection sections={treatmentSections} />
        </>
      ) : service.body ? (
        <div class="service-body prose">
          <PortableText value={service.body} />
        </div>
      ) : null}
    </div>

    <CTABanner />
  </article>
</BaseLayout>

<style>
  .service-detail {
    padding-bottom: var(--space-20);
  }

  .service-hero {
    width: 100%;
    aspect-ratio: 16 / 5;
    max-height: 480px;
    overflow: hidden;
  }

  .service-hero :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .service-header {
    max-width: var(--max-width-narrow);
    padding-block: var(--space-12);
  }

  .service-header h1 {
    margin-bottom: var(--space-4);
  }

  .service-meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
  }

  .badge {
    display: inline-block;
    padding: var(--space-1) var(--space-4);
    background-color: var(--color-accent);
    color: var(--color-primary);
    font-size: var(--font-size-sm);
    font-weight: 500;
    border-radius: var(--radius-full);
    border: 1px solid var(--color-secondary);
  }

  .service-body {
    padding-bottom: var(--space-16);
  }

  /* PortableText inline images (for non-sectioned pages) */
  .service-body :global(img) {
    border: 3px solid var(--color-secondary);
    border-radius: 15px;
  }
</style>
