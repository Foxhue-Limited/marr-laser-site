---
import BaseLayout from '@layouts/BaseLayout.astro';
import FAQAccordion from '@components/FAQAccordion.astro';
import { sanityClient } from '@lib/sanity';
import { faqsQuery } from '@lib/queries';
import type { FAQ } from '@foxhue/shared';

const faqs: FAQ[] = await sanityClient.fetch(faqsQuery);
---

<BaseLayout title="FAQ" description="Frequently asked questions and answers.">
  <section class="faq-hero">
    <div class="container">
      <p class="eyebrow">Support</p>
      <h1 class="faq-title">Frequently Asked Questions</h1>
    </div>
  </section>

  <section class="faq-page">
    <div class="container">
      <FAQAccordion faqs={faqs} heading="" />
    </div>
  </section>
</BaseLayout>

<style>
  .faq-hero {
    background-color: var(--color-accent);
    padding-block: var(--space-16);
    text-align: center;
  }

  .faq-title {
    font-family: var(--font-heading);
    font-size: var(--font-size-4xl);
    font-weight: var(--font-weight-heading-light);
    color: var(--color-primary);
  }

  .faq-page {
    padding-block: var(--space-16);
  }
</style>
